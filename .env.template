# Copy this file to .env (gitignored) and fill in your values.
# Used by scripts/build-and-sign-mac.sh (pnpm build:mac). See CONTRIBUTING.md.

# Apple ID email used for notarization. Required.
APPLE_ID="you@example.com"

# App-specific password from appleid.apple.com (Sign-In and Security).
# Leave this unset to be prompted at build time so it never lands on disk.
# APPLE_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Optional. The Developer ID Application certificate and Team ID are auto-detected
# from your keychain (security find-identity -v -p codesigning). Set these only to
# pin a specific identity, e.g. if you hold more than one signing certificate.
# APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
# APPLE_TEAM_ID="XXXXXXXXXX"
