{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Overdone",
  "version": "0.1.0",
  "identifier": "co.overpolish.overdone",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "overdone",
        "width": 375,
        "height": 325,
        "minWidth": 240,
        "minHeight": 240,
        "visible": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "acceptFirstMouse": true
      },
      {
        "label": "panel",
        "title": "overdone",
        "width": 360,
        "height": 440,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true,
        "visible": false,
        "acceptFirstMouse": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/media/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
